#!/usr/bin/env bash
set -ex
pwd
ls ../data
# Single Example: python -u run_capsule.py -i ../data/zstacks/scan_00008-REF_Ch2.ome.tif -o ../results/ --motionAmp 4 --brightness 0.6 --nsites 30 --SimDescription 740

# Define the default settings for motionAmp, brightness, spikeAmp, and nsites
motionAmp_values=(4)
brightness_values=(0.6)
spikeAmp_values=(3)
nsites_values=(30)
# Define the ranges for motionAmp, brightness, spikeAmp, and nsites
# motionAmp_values=(0 2 6 8)
# brightness_values=(0.06 0.2 2 6)
# spikeAmp_values=(1 2 4)
# nsites_values=(10 20 40 50)

# Base command
base_command="python -u run_capsule.py"

# Counter for test directories and SimDescription
counter=1

# Maximum number of parallel processes
max_parallel=8 # Adjust based on your system's capabilities

# Output directory for results
output_dir="../results/"

# Create the output directory if it doesn't exist
mkdir -p "$output_dir"


# Get all zstack tif files
files=$(find ../data/zstacks/ -maxdepth 1 -mindepth 1 | sort)

# Initialize the CSV file
csv_file="${output_dir}parameters.csv"
echo "SimDescription,motionAmp,brightness,spikeAmp,nsites,scan" > "$csv_file"

# Pre-generate all CSV entries to avoid concurrent writes
for motionAmp in "${motionAmp_values[@]}"; do
  for brightness in "${brightness_values[@]}"; do
    for spikeAmp in "${spikeAmp_values[@]}"; do
      for nsites in "${nsites_values[@]}"; do
        for file in $files; do
          echo "$counter,$motionAmp,$brightness,$spikeAmp,$nsites,$(basename $file)" >> "$csv_file"
          counter=$((counter + 1))
        done
      done
    done
  done
done

# Reset counter for command execution
counter=1

# Function to run a command without modifying the CSV
run_command() {
  local input_file=$1
  local motionAmp=$2
  local brightness=$3
  local spikeAmp=$4
  local nsites=$5
  local counter=$6
  local output_path="${output_dir}"
  
  # Create the output directory if it doesn't exist
  mkdir -p "$output_path"
  
  # Construct the full command
  local full_command="$base_command -i $input_file -o $output_path --motionAmp $motionAmp --brightness $brightness --spikeAmp $spikeAmp --nsites $nsites --SimDescription $counter"
  
  # Retry logic
  local max_retries=5 
  local attempt=0
  local success=0
  
  while [ $attempt -lt $max_retries ]; do
    attempt=$((attempt + 1))
    echo "Attempt $attempt: Running: $full_command"
    
    # Run the command
    eval "$full_command" && success=1 && break
    
    if [ $? -ne 0 ]; then
      echo "Attempt $attempt failed. Retrying..."
      sleep 1  # Optional: wait before retrying
    fi
  done
  
  if [ $success -eq 0 ]; then
    echo "Command failed after $max_retries attempts."
    exit 1
  fi
}

# Loop through all combinations and execute commands in parallel
for motionAmp in "${motionAmp_values[@]}"; do
  for brightness in "${brightness_values[@]}"; do
    for spikeAmp in "${spikeAmp_values[@]}"; do
      for nsites in "${nsites_values[@]}"; do
        for file in $files; do
          run_command "$file" "$motionAmp" "$brightness" "$spikeAmp" "$nsites" "$counter" &
          
          # Increment the counter
          counter=$((counter + 1))

          # Control parallel processes
          while [ "$(jobs -r | wc -l)" -ge "$max_parallel" ]; do
            wait -n
          done

          # Small delay to maintain order (optional)
          sleep 0.05
        done
      done
    done
  done
done

# Wait for all background processes to complete
wait